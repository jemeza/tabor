ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Modal sandbox credentials (required for sandbox tool)
# Obtain from https://modal.com/settings — or run: modal token new
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# LangSmith tracing (optional — remove or set LANGSMITH_TRACING=false to disable)
LANGSMITH_TRACING=true_or_false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=your_project_name_here
